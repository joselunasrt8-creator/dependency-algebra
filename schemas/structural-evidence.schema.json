{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dependency-algebra.local/schemas/structural-evidence.schema.json",
  "title": "SYNAPSE Canonical Registered Dependency-Analysis Evidence Artifact v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_schema_version", "analysis", "input", "result", "diagnostics", "provenance", "artifact_hash"],
  "properties": {
    "artifact_schema_version": {"const": "dependency-algebra.structural-evidence.v2"},
    "analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["analysis_id", "analysis_version", "accepted_input", "deterministic_configuration", "specification_references", "implementation_identity", "output_contract_identity"],
      "properties": {
        "analysis_id": {"const": "dependency-algebra.dependency-analysis"},
        "analysis_version": {"type": "string", "minLength": 1},
        "accepted_input": {"type": "string", "minLength": 1},
        "deterministic_configuration": {"type": "object"},
        "specification_references": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "implementation_identity": {"type": "string", "minLength": 1},
        "output_contract_identity": {"type": "string", "minLength": 1}
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_topology_hash", "normalized_ir_hash"],
      "properties": {
        "source_topology_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "normalized_ir_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation_contract", "validation_status", "result_hash", "payload"],
      "properties": {
        "validation_contract": {"const": "dependency-algebra.result-validation.v1"},
        "validation_status": {"const": "VALIDATED"},
        "result_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "payload": {"type": "object"}
      }
    },
    "diagnostics": {"type": "array"},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compiler_package_version"],
      "properties": {"compiler_package_version": {"type": "string"}}
    },
    "artifact_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
  }
}

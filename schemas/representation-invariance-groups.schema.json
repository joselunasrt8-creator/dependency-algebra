{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synapse.local/schemas/representation-invariance-groups.schema.json",
  "title": "SYNAPSE representation invariance fixture groups",
  "type": "object",
  "required": ["schema_version", "groups"],
  "properties": {
    "schema_version": {"const": "synapse.representation-invariance-groups.v1"},
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["group_id", "semantic_identity", "analysis_id", "configuration", "baseline", "representations", "expected"],
        "properties": {
          "group_id": {"type": "string", "minLength": 1},
          "semantic_identity": {"type": "string", "minLength": 1},
          "description": {"type": "string"},
          "analysis_id": {"type": "string", "minLength": 1},
          "configuration": {"type": "object"},
          "baseline": {"type": "string", "minLength": 1},
          "representations": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 1}},
          "expected": {
            "type": "object",
            "required": ["normalized_ir_hash", "result_hash", "artifact_hash", "classification", "diagnostics"],
            "properties": {
              "normalized_ir_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
              "result_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
              "artifact_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
              "classification": {"enum": ["VALID", "DEGRADED", "NULL"]},
              "diagnostics": {"type": "array"}
            },
            "additionalProperties": false
          },
          "analysis_specific": {"type": "object"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

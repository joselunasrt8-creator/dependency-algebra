{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dependency-algebra.local/schemas/projection.schema.json",
  "title": "Dependency Algebra Traversal Projection v1",
  "description": "The serialized shape of dependency_algebra.ir.ProjectedIR.",
  "type": "object",
  "additionalProperties": false,
  "required": ["removed", "adjacency", "roots"],
  "properties": {
    "removed": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "adjacency": { "$ref": "#/$defs/adjacency" },
    "roots": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-zA-Z0-9_.-]+$" },
    "adjacency_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edge_id", "component_id"],
      "properties": {
        "edge_id": { "$ref": "#/$defs/id" },
        "component_id": { "$ref": "#/$defs/id" }
      }
    },
    "adjacency": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "#/$defs/adjacency_edge" }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dependency-algebra.local/schemas/projection.schema.json",
  "title": "Dependency Algebra Complement Projection Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "topology_id", "normalized_ir_hash", "candidate_set", "diagnostics"],
  "properties": {
    "schema_version": { "const": "dependency-algebra.projection.v1" },
    "topology_id": { "$ref": "#/$defs/id" },
    "normalized_ir_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "candidate_set": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/id" } },
    "projected_ir_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "projected_ir": { "$ref": "ir.schema.json" },
    "diagnostics": { "type": "array", "items": { "$ref": "#/$defs/diagnostic" } }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-zA-Z0-9_.-]+$" },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message", "subject"],
      "properties": {
        "code": { "enum": ["PROJECTION.UNKNOWN_COMPONENT", "PROJECTION.EMPTY_CANDIDATE_SET", "PROJECTION.DUPLICATE_CANDIDATE", "PROJECTION.REMOVED_ROOT", "PROJECTION.REMOVED_TARGET", "PROJECTION.COMPONENT_REMOVED"] },
        "severity": { "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "minLength": 1 },
        "subject": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "id"],
          "properties": {
            "kind": { "enum": ["projection", "candidate", "component", "edge", "root", "target", "workload"] },
            "id": { "type": "string" }
          }
        }
      }
    }
  }
}
